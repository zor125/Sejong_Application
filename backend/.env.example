# Runtime mode. Use production in Railway.
NODE_ENV=development

# Local development port. Railway supplies PORT automatically.
PORT=3000

# Supabase PostgreSQL connection URI. Never commit a real password or URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Use a long, random secret in every deployed environment.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=3600

# Exact browser origins, separated by commas. Wildcards are not supported.
# Localhost origins are allowed by the server by default; keep deployed Vercel
# origins here when running on Railway.
CORS_ORIGIN=https://your-admin-web.vercel.app,https://your-student-app.vercel.app

# Kakao OAuth REST API key. Register it in Railway Variables only.
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Optional Kakao client secret. Leave blank if Kakao client secret is disabled.
KAKAO_CLIENT_SECRET=

# Exact redirect URIs allowed for Kakao OAuth. Separate multiple values with commas.
# Do not use wildcards, prefix matching, or arbitrary subdomain patterns.
KAKAO_ALLOWED_REDIRECT_URIS=https://your-student-app.example.com,http://localhost:8081


# Optional. Enables AI-assisted PDF question import when set in Backend runtime only.
OPENAI_API_KEY=
OPENAI_PDF_IMPORT_MODEL=gpt-4.1-mini

# Optional. Used only for GPT-5 family PDF import models. Allowed examples: low, medium.
OPENAI_PDF_IMPORT_REASONING_EFFORT=low
