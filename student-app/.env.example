# Railway Backend URL used by Expo and React Native.
EXPO_PUBLIC_API_BASE_URL=https://sejongapplication-production.up.railway.app

# Optional Vite fallback when this project is built/run with Vite tooling.
VITE_API_BASE_URL=https://sejongapplication-production.up.railway.app

# Optional fixed Kakao redirect URI.
# Web can usually use the current origin. Native apps use nursing-student-app://kakao/oauth.
EXPO_PUBLIC_KAKAO_REDIRECT_URI=

# Local backend example:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# VITE_API_BASE_URL=http://localhost:3000
